# === Redis (message broker between services) ===
REDIS_URL=redis://redis:6379/0

# === Telegram Collector (Telethon userbot) ===
# Get credentials at https://my.telegram.org/apps
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here
# Telegram folder ID to monitor (optional, monitors all groups if not set)
TG_FOLDER_ID=

# === Reddit Collector ===
# Register app at https://www.reddit.com/prefs/apps (type: script)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=offer-aggregator/1.0

# === Filter Service ===
# Anthropic API key for LLM classification
ANTHROPIC_API_KEY=sk-ant-...

# === Publisher (Aiogram bot) ===
# Create bot via @BotFather
PUBLISHER_BOT_TOKEN=
# Chat ID where filtered offers will be posted
PUBLISHER_TARGET_CHAT_ID=
